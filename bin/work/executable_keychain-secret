#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'Usage:\n' >&2
  printf '  %s get <service> <account>\n' "$0" >&2
  printf '  %s set <service> <account> [value]\n' "$0" >&2
}

if [[ $# -lt 1 ]]; then
  usage
  exit 64
fi

command=$1
shift

case "$command" in
get)
  if [[ $# -ne 2 ]]; then
    usage
    exit 64
  fi

  service=$1
  account=$2

  if ! value=$(security find-generic-password -s "$service" -a "$account" -w 2>/dev/null); then
    printf 'Missing or unreadable Keychain secret: service=%s account=%s\n' "$service" "$account" >&2
    exit 1
  fi
  printf '%s\n' "$value"
  ;;
set)
  if [[ $# -lt 2 || $# -gt 3 ]]; then
    usage
    exit 64
  fi

  service=$1
  account=$2
  if [[ $# -eq 3 ]]; then
    value=$3
  else
    value=$(cat)
  fi

  security add-generic-password -U -s "$service" -a "$account" -w "$value" >/dev/null
  ;;
*)
  usage
  exit 64
  ;;
esac
