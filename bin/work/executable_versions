lambda_ping() {
  local env="$1" region="$2" fn="$3" label="$4"
  local tmp="${label}-${env}.json"
  echo "printf '$env '; aws --region $region lambda invoke \
    --function-name $fn \
    --cli-binary-format raw-in-base64-out \
    --payload '{\"ping\": 1}' $tmp > /dev/null && jq -r '.appVersion' $tmp && rm $tmp"
}

cmds+=('echo -e "\n\npost-metric lambda"')
cmds+=("$(lambda_ping prod ca-central-1 post-metrics-Function-JQwkOV9M3BPp post-metric)")

cmds+=('echo -e "\n\ninvoice anomaly detection lambda"')
cmds+=("$(lambda_ping prod ca-central-1 invoice-anomaly-detection-Function-BVrJFsOZ2oKr anomaly)")

cmds+=('echo -e "\n\nomnivore alerter"')
