cmds+=("$(lambda_ping staging us-east-2 ready-billing-runner-ReadyBillingRunner-J6CX10B9AP6H billing-runner)")
cmds+=("$(lambda_ping prod ca-central-1 ready-billing-runner-ReadyBillingRunner-1L44YGZWFYYWQ billing-runner)")


parallel -j 200% -k ::: "${cmds[@]}"
