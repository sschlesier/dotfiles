#! /usr/bin/env bash
set -euo pipefail

# Extract a JWT from the clipboard: Authorization header, ID-TOKEN cookie, or raw token.
clipboard_content=$(pbpaste)

# Check if clipboard contains an Authorization header
if [[ $clipboard_content == *Bearer* ]]; then
  pbpaste | sed 's/.* //' | sed 's/"$//' |  sed 's/.*"//'
fi

# Check if clipboard contains an ID-TOKEN cookie
if [[ $clipboard_content == *ID-TOKEN=* ]]; then
  pbpaste | awk -F ';' '{printf "%s", $1}' | sed 's/.*=//'
fi

trimmed=$(printf '%s' "$clipboard_content" | sed -e 's/^[[:space:]"'\''"]*//' -e 's/[[:space:]"'\''"]*$//')

if [[ $trimmed =~ ^[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+$ ]]; then
  printf '%s' "$trimmed"
fi
