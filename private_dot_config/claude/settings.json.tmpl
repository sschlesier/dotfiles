{{- $themeFile := joinPath (env "XDG_DATA_HOME") "theme_mode" -}}
{{- $mode := "dark" -}}
{{- if stat $themeFile }}{{ $mode = trim (output "cat" $themeFile) }}{{ end -}}
{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(cargo *)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "{{ joinPath (env "XDG_CONFIG_HOME") "claude" "statusline.sh" }}",
    "padding": 1
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "theme": "{{ if eq $mode "light" }}{{ .claude_light_theme }}{{ else }}{{ .claude_dark_theme }}{{ end }}",
  "editorMode": "vim",
  "preferredNotifChannel": "kitty",
  "skipAutoPermissionPrompt": true
}
