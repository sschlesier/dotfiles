{{- $themeFile := joinPath (env "XDG_DATA_HOME") "theme_mode" -}}
{{- $mode := "dark" -}}
{{- if stat $themeFile }}{{ $mode = trim (output "cat" $themeFile) }}{{ end -}}
{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(cargo *)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(aws secretsmanager *)",
      "Bash(aws ssm get-parameter*)",
      "Bash(aws ssm get-parameters*)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"additionalContext\": \"COMMIT REMINDER: Each commit must represent one idea. Do not bundle unrelated changes. No attribution trailers (no Co-Authored-By, no Signed-off-by).\"}}'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "{{ joinPath (env "XDG_CONFIG_HOME") "claude" "statusline.sh" }}",
    "padding": 1
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "theme": "{{ if eq $mode "light" }}{{ .claude_light_theme }}{{ else }}{{ .claude_dark_theme }}{{ end }}",
  "editorMode": "vim",
  "preferredNotifChannel": "notifications_disabled",
  "skipAutoPermissionPrompt": true
}
