function llb () {
    output=$(
		(cd $XDG_BIN_HOME && fd --type executable .) &&
        (cd $HOME/.config/zsh/functions && fd . | sed 's/$/()/')
    )
    if [[ -n $1 ]]
    then
      output=$(echo $output | rg "$1")
    fi
	if [ -t 1 ]; then
        echo "$output" | column
	else
		echo "$output"
	fi
}
